generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum TaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum MeetingType {
  TEAM_SYNC
  SUPERVISOR
  REVIEW
  OTHER
}

enum PinnedCategory {
  INSTRUCTIONS
  CRITICAL
  DECISION
  RESOURCES
  ANNOUNCEMENT
}

enum MilestoneStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETED
  DELAYED
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  avatarUrl    String?
  createdAt    DateTime @default(now())

  ownedWorkspaces  Workspace[]       @relation("WorkspaceOwner")
  memberships      WorkspaceMember[]
  createdTasks     Task[]            @relation("TaskCreator")
  assignedSubtasks SubTask[]         @relation("SubtaskAssignee")
  uploadedFiles    File[]            @relation("FileUploader")
  sentMessages     Message[]         @relation("MessageSender")
  receivedMessages Message[]         @relation("MessageReceiver")
  pinnedItems      PinnedItem[]      @relation("PinnedItemAuthor")
  actionItems      ActionItem[]      @relation("ActionItemAssignee")
  meetingAttendees MeetingAttendee[]

  @@map("users")
}

// ─── Workspace ────────────────────────────────────────────────────────────────

model Workspace {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  ownerId     String
  createdAt   DateTime @default(now())

  owner       User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members     WorkspaceMember[]
  tasks       Task[]
  files       File[]
  meetings    Meeting[]
  messages    Message[]
  pinnedItems PinnedItem[]
  milestones  Milestone[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        Role     @default(MEMBER)
  joinedAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

// ─── Tasks ────────────────────────────────────────────────────────────────────

model Task {
  id          String       @id @default(cuid())
  workspaceId String
  createdById String?
  title       String
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy User?     @relation("TaskCreator", fields: [createdById], references: [id])
  subtasks  SubTask[]

  @@map("tasks")
}

model SubTask {
  id          String   @id @default(cuid())
  taskId      String
  assigneeId  String?
  dependsOnId String?
  title       String
  note        String   @default("")
  dueDate     String?
  done        Boolean  @default(false)
  createdAt   DateTime @default(now())

  task       Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  assignee   User?     @relation("SubtaskAssignee", fields: [assigneeId], references: [id])
  dependsOn  SubTask?  @relation("SubtaskDependency", fields: [dependsOnId], references: [id])
  dependents SubTask[] @relation("SubtaskDependency")

  @@map("subtasks")
}

// ─── Files ────────────────────────────────────────────────────────────────────

model File {
  id           String   @id @default(cuid())
  workspaceId  String
  uploadedById String
  name         String
  url          String
  type         String
  folder       String   @default("General")
  size         String
  createdAt    DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  uploader  User      @relation("FileUploader", fields: [uploadedById], references: [id])

  @@map("files")
}

// ─── Meetings ─────────────────────────────────────────────────────────────────

model Meeting {
  id          String      @id @default(cuid())
  workspaceId String
  title       String
  date        String
  time        String
  type        MeetingType
  duration    Int
  createdAt   DateTime    @default(now())

  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  attendees MeetingAttendee[]
  notes     MeetingNote[]
  actions   ActionItem[]

  @@map("meetings")
}

model MeetingAttendee {
  meetingId String
  userId    String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([meetingId, userId])
  @@map("meeting_attendees")
}

model MeetingNote {
  id        String @id @default(cuid())
  meetingId String
  text      String

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_notes")
}

model ActionItem {
  id         String  @id @default(cuid())
  meetingId  String
  assigneeId String?
  text       String
  done       Boolean @default(false)

  meeting  Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  assignee User?   @relation("ActionItemAssignee", fields: [assigneeId], references: [id])

  @@map("action_items")
}

// ─── Messages ─────────────────────────────────────────────────────────────────

model Message {
  id          String   @id @default(cuid())
  workspaceId String
  senderId    String
  receiverId  String?
  room        String   @default("general")
  text        String
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sender    User      @relation("MessageSender", fields: [senderId], references: [id])
  receiver  User?     @relation("MessageReceiver", fields: [receiverId], references: [id])

  @@map("messages")
}

// ─── Pinned Items ─────────────────────────────────────────────────────────────

model PinnedItem {
  id          String         @id @default(cuid())
  workspaceId String
  addedById   String
  category    PinnedCategory
  title       String
  body        String
  pinned      Boolean        @default(true)
  createdAt   DateTime       @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  addedBy   User      @relation("PinnedItemAuthor", fields: [addedById], references: [id])

  @@map("pinned_items")
}

// ─── Timeline ─────────────────────────────────────────────────────────────────

model Milestone {
  id          String          @id @default(cuid())
  workspaceId String
  title       String
  description String?
  dueDate     String
  status      MilestoneStatus @default(UPCOMING)
  createdAt   DateTime        @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("milestones")
}
